# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional extra keys — Saarthi auto-rotates to the next one when a key hits its
# free-tier quota (HTTP 429). Add as many as you like.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# (alternatively, one comma-separated list instead of the numbered vars)
# GEMINI_API_KEYS=key1,key2,key3

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
PORT=8787

# Prachar news-reels — stock images. Free key at https://www.pexels.com/api/
# (without it, Prachar falls back to keyless Pollinations image generation)
PEXELS_API_KEY=

# --- Telegram bot (optional) ---
# 1) Create a bot with @BotFather on Telegram, then paste its token here
TELEGRAM_BOT_TOKEN=
# 2) Your deployed app URL for "open in app" deep links, e.g. https://saarthi.vercel.app
APP_URL=
