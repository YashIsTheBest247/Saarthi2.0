# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional extra keys — Saarthi auto-rotates to the next one when a key hits its
# free-tier quota (HTTP 429). Add as many as you like.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# (alternatively, one comma-separated list instead of the numbered vars)
# GEMINI_API_KEYS=key1,key2,key3

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
PORT=8787

# Pragyan news-reels — stock images. Free key at https://www.pexels.com/api/
# (without it, Pragyan falls back to keyless Pollinations image generation)
PEXELS_API_KEY=

# --- Telegram bot (optional) ---
# 1) Create a bot with @BotFather on Telegram, then paste its token here
TELEGRAM_BOT_TOKEN=
# 2) Your deployed app URL for "open in app" deep links, e.g. https://saarthi.vercel.app
APP_URL=

# --- Email notifications (optional) ---
# "Email me when it's done" sends a real email (with a calendar .ics attached) to
# any recipient. For Gmail: enable 2-Step Verification, create an App Password at
# https://myaccount.google.com/apppasswords and put it in SMTP_PASSWORD.
# Without credentials the API runs in demo mode.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# --- Emergency SMS (optional) ---
# The Telegram bot can text a user's emergency contact (after a "shall I text them?" confirm).
# Without any key it uses TextBelt's free shared key (~1 SMS/day — demo only).
# For reliable Indian delivery, add a Fast2SMS key (free credits at fast2sms.com):
FAST2SMS_KEY=
# Or a paid TextBelt key (textbelt.com):
TEXTBELT_KEY=
